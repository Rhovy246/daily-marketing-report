# ---------------------------------------------------------------------------
# Daily Marketing Report — environment variables
#
# Copy this file to `.env.local` for local development, and set the same
# variables in the Vercel project dashboard (Settings → Environment Variables)
# for production. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Meta (Facebook) Marketing API ---------------------------------------
# A long-lived System User access token with ads_read permission.
# Generate in Meta Business Settings → System Users → Generate New Token.
META_ACCESS_TOKEN=

# Your ad account ID. Accepts either the bare digits (1234567890) or the
# full "act_1234567890" form — the code normalizes it.
META_AD_ACCOUNT_ID=

# --- HubSpot CRM ----------------------------------------------------------
# A Private App access token with the crm.objects.contacts.read scope.
# Create under Settings → Integrations → Private Apps.
HUBSPOT_ACCESS_TOKEN=

# --- Anthropic (Claude) ---------------------------------------------------
# API key from https://console.anthropic.com — used to write the email.
ANTHROPIC_API_KEY=

# --- Resend (email delivery) ---------------------------------------------
# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Who the daily report goes to (the sales director / boss).
REPORT_TO_EMAIL=

# The verified sender address, e.g. "Powerhouse Reports <reports@yourdomain.com>".
# The domain must be verified in Resend.
REPORT_FROM_EMAIL=

# Your own email — receives failure alerts and ?test=1 dry-run reports.
ALERT_EMAIL=

# --- Performance targets (optional) --------------------------------------
# Used for the "Targets & pacing" summary and the "What to change today"
# recommendations. Leave any blank to skip the advice that depends on it.
# Numbers only (no $ or commas).

# Target cost per lead, in USD (e.g. 10).
TARGET_CPL=

# Monthly lead goal (e.g. 1000).
MONTHLY_LEAD_GOAL=

# Total monthly ad budget, in USD (e.g. 6500).
MONTHLY_AD_BUDGET=

# --- Cron security --------------------------------------------------------
# A random secret. Vercel Cron automatically sends this as
# "Authorization: Bearer <CRON_SECRET>" when CRON_SECRET is set on the project.
# Generate one with:  openssl rand -hex 32
CRON_SECRET=
